# Скопіювати в .env для локального запуску (НЕ комітити .env у Git)

# Рядок підключення до Postgres з Neon.tech (Connection string, режим "Pooled connection")
DATABASE_URL=postgresql://user:password@host/dbname

# Будь-який довгий випадковий рядок — використовується для підпису токенів CRM-панелі
SECRET_KEY=change-me-to-a-long-random-string

# Пароль для входу в CRM-панель
ADMIN_PASSWORD=change-me
